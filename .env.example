# Copy this file to ".env.local" and fill in your Supabase project values.
# Without these, the app runs in local-only mode (data stays in the browser).
# Both values are safe to expose in the browser (the anon key is public by design;
# Row-Level Security protects each user's data).

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
